DEEPSEEK_API_KEY=sk-your-deepseek-api-key-here
DEEPSEEK_ANALYSIS_MODEL=deepseek-chat
ARK_API_KEY=your-volcengine-ark-api-key-here
ARK_BASE_URL=https://ark.cn-beijing.volces.com/api/v3
VIDEO_PROVIDER=ark_seedance
ARK_VIDEO_MODEL_SEEDANCE_2_0=doubao-seedance-2-0-260128
SEED_ANALYSIS_MODEL=doubao-seed-2-0-lite-260215
GEMINI_API_KEY=your-gemini-api-key-here
# GPT Image 2：与 VectorEngine 同一家时可留空下面两项，自动使用 VECTORENGINE_*；单独填则优先。
GPT_IMAGE_2_API_KEY=
GPT_IMAGE_2_BASE_URL=
GPT_IMAGE_2_MODEL=gpt-image-2
VECTORENGINE_API_KEY=your-vectorengine-relay-api-key-here
VECTORENGINE_BASE_URL=https://api.vectorengine.ai/v1
# VectorEngine 图片中转站：
# Nano banana pro 对应的模型名
VECTORENGINE_MODEL_NANO_BANANA_PRO=gemini-3-pro-image-preview
# Nano Banana 2 对应的模型名
VECTORENGINE_MODEL_NANO_BANANA_2=gemini-3.1-flash-image-preview
# 只有你想保留旧视频通道时才需要
DASHSCOPE_API_KEY=your-dashscope-api-key-here
FFMPEG_PATH=
