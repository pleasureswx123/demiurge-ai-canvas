{
  "name": "my-canvas",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "concurrently -n web,img -c cyan,magenta \"vite\" \"node server/run-image-service-dev.mjs\"",
    "dev:web": "vite",
    "dev:api": "node server/deepseek-proxy.js",
    "dev:image-api": "node server/run-image-service-dev.mjs",
    "dev:image-api:once": "python server/image_generate_service.py",
    "dev:all": "concurrently -n api,web,img -c yellow,cyan,magenta \"npm run dev:api\" \"vite\" \"node server/run-image-service-dev.mjs\"",
    "build": "vite build",
    "lint": "eslint .",
    "preview": "vite preview"
  },
  "dependencies": {
    "@xyflow/react": "^12.10.2",
    "clsx": "^2.1.1",
    "concurrently": "^9.2.1",
    "dotenv": "^17.4.2",
    "framer-motion": "^12.38.0",
    "lucide-react": "^1.8.0",
    "openai": "^6.34.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "reactflow": "^11.11.4",
    "tailwind-merge": "^3.5.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "autoprefixer": "^10.4.27",
    "eslint": "^9.39.4",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.4.0",
    "postcss": "^8.5.9",
    "tailwindcss": "^3.4.17",
    "vite": "^8.0.4"
  }
}
